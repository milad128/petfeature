@startuml petfeature-use-cases
left to right direction
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor #FEFEFE
  BorderColor #333333
}
skinparam actor {
  BorderColor #333333
}

title petfeature.ir — Use Case Diagram (v1 Library · v2 Blog · v3 Tools)

actor "بازدیدکننده\n(Visitor)" as Visitor
actor "مدیر\n(Milad Mirzaei)" as Admin
actor "شبکه‌های اجتماعی\n(Social Networks)" as Social <<system>> <<v2>>

rectangle "petfeature.ir" {

  ' --- v1: Library ---
  usecase "مرور کتابخانه\n(Browse Book Library)" as UC_Library
  usecase "مشاهده جزئیات کتاب\n(View Book Details)" as UC_BookDetail
  usecase "بازدید از درباره من\n(Visit About Me)" as UC_About

  ' --- v2: Blog ---
  usecase "مرور بلاگ\n(Browse Blog)" as UC_Blog <<v2>>
  usecase "خواندن پست\n(Read Post)" as UC_ReadPost <<v2>>
  usecase "امتیازدهی به پست\n(Rate Post)" as UC_RatePost <<v2>>
  usecase "ثبت نظر روی پست\n(Comment on Post)" as UC_CommentPost <<v2>>
  usecase "اشتراک‌گذاری\n(Share to Social Networks)" as UC_Share <<v2>>
  usecase "کپی لینک\n(Copy Link)" as UC_CopyLink <<v2>>

  ' --- v3: Tools ---
  usecase "مرور ابزارها\n(Browse Tools)" as UC_Tools <<v3>>
  usecase "استفاده از ابزار\n(Use a Tool)" as UC_UseTool <<v3>>

  ' --- v1: Admin ---
  usecase "مدیریت محتوای کتاب‌ها\n(Manage Library Content)" as UC_ManageBooks
  usecase "مدیریت درباره نویسنده\n(Manage About Author Content)" as UC_ManageAbout

  ' --- v2: Admin ---
  usecase "مدیریت پست‌های بلاگ\n(Manage Blog Posts)" as UC_ManagePosts <<v2>>
  usecase "مدیریت نظرات پست\n(Moderate Post Comments)" as UC_ModeratePostComments <<v2>>

  ' --- v3: Admin ---
  usecase "مدیریت ابزارها\n(Manage Tools)" as UC_ManageTools <<v3>>
}

' --- Visitor: v1 ---
Visitor --> UC_Library
Visitor --> UC_About

' --- Visitor: v2 ---
Visitor --> UC_Blog

' --- Visitor: v3 ---
Visitor --> UC_Tools

' --- Browse library includes ---
UC_Library ..> UC_BookDetail : <<include>>

' --- Browse blog includes ---
UC_Blog ..> UC_ReadPost : <<include>>
UC_Blog ..> UC_RatePost : <<include>>
UC_Blog ..> UC_CommentPost : <<include>>
UC_Blog ..> UC_Share : <<include>>
UC_Blog ..> UC_CopyLink : <<include>>

' --- Browse tools includes ---
UC_Tools ..> UC_UseTool : <<include>>

' --- External systems ---
UC_Share --> Social

' --- Admin: v1 ---
Admin --> UC_ManageBooks
Admin --> UC_ManageAbout

' --- Admin: v2 ---
Admin --> UC_ManagePosts
Admin --> UC_ModeratePostComments

' --- Admin: v3 ---
Admin --> UC_ManageTools

note right of UC_Library
  v1 — shipped:
  browse + detail,
  categories, media links,
  downloads, referred books
end note

note right of UC_Blog
  v2 — blog:
  read posts (یادداشت),
  star rating, comments,
  share + copy link,
  view counts
end note

note right of UC_Tools
  v3 — tools:
  downloadable PM templates,
  usage guides, cross-linked
  to books and posts
end note

legend right
  |= Stereotype |= Meaning |
  | <<v2>> | Planned for version 2 |
  | <<v3>> | Planned for version 3 |
  | <<include>> | Always part of parent use case |
  | <<system>> | External actor / system |
endlegend

@enduml
