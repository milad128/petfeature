# Copy to .env for local development: cp .env.example .env

# App
APP_NAME=petfeature
DEBUG=true
SECRET_KEY=change-me-in-production

# Server (Hamravesh sets PORT; default 8000)
PORT=8000

# Database (Hamravesh PostgreSQL addon provides DATABASE_URL)
# Local dev without Docker:
# DATABASE_URL=sqlite+aiosqlite:///./petfeature.db
DATABASE_URL=postgresql+asyncpg://petfeature:petfeature@localhost:5432/petfeature

# Admin session (for CMS later)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
